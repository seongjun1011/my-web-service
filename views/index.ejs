<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SmartPantry</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    
    <script>
        (function() {
            const savedTheme = localStorage.getItem('pantry-theme') || 'light';
            document.documentElement.setAttribute('data-theme', savedTheme);
        })();
    </script>

    <style>
        /* --- 🎨 테마 변수 (우선순위 강화를 위해 :root와 [data-theme] 분리) --- */
        :root { 
            --bg-gray: #f2f2f7; --card-bg: #ffffff; --text-main: #1c1c1e; 
            --text-sub: #8e8e93; --accent: #007aff; --header-bg: #ffffff;
            --modal-overlay: rgba(0,0,0,0.5);
        }

        /* 다크모드 변수 강제 적용 */
        [data-theme='dark'] {
            --bg-gray: #000000 !important; 
            --card-bg: #1c1c1e !important; 
            --text-main: #ffffff !important; 
            --text-sub: #8e8e93 !important; 
            --accent: #0a84ff !important; 
            --header-bg: #1c1c1e !important;
            --modal-overlay: rgba(0,0,0,0.85) !important;
        }

        body { 
            font-family: -apple-system, sans-serif; background-color: var(--bg-gray); 
            margin: 0; padding-bottom: 90px; color: var(--text-main); 
            transition: background 0.2s, color 0.2s; overflow-x: hidden;
        }
        
        .header { background: var(--header-bg); padding: 12px 20px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(150,150,150,0.2); position: sticky; top: 0; z-index: 100; }
        .header h1 { font-size: 1.1rem; margin: 0; font-weight: 800; color: var(--accent); }
        
        .user-menu-container { position: relative; }
        .user-icon { font-size: 1.4rem; cursor: pointer; background: rgba(150,150,150,0.2); border-radius: 50%; width: 35px; height: 35px; display: flex; align-items: center; justify-content: center; }
        
        .dropdown-menu { display: none; position: absolute; top: 45px; right: 0; background: var(--card-bg); min-width: 180px; border-radius: 15px; box-shadow: 0 10px 25px rgba(0,0,0,0.2); overflow: hidden; z-index: 1000; border: 1px solid rgba(150,150,150,0.2); }
        .dropdown-menu.show { display: block; animation: slideDown 0.3s ease; }
        .dropdown-item { padding: 12px 15px; display: flex; align-items: center; text-decoration: none; color: var(--text-main); font-size: 0.9rem; cursor: pointer; }
        .dropdown-item:hover { background: rgba(150,150,150,0.1); }

        .page { display: none; }
        .page.active { display: block; }

        .analysis-card, .item-card, .modal-content { background: var(--card-bg); color: var(--text-main); transition: background 0.2s; }
        .item-card { border-radius: 18px; padding: 15px; margin: 12px 20px; display: flex; align-items: center; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
        
        .bottom-nav { position: fixed; bottom: 0; width: 100%; background: var(--header-bg); display: flex; border-top: 1px solid rgba(150,150,150,0.2); padding: 10px 0 25px; }
        .nav-tab { flex: 1; text-align: center; font-size: 1.5rem; color: #b0b0b0; cursor: pointer; }
        .nav-tab.active { color: var(--text-main); }

        .custom-modal { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: var(--modal-overlay); z-index: 1500; display: none; justify-content: center; align-items: center; }
        .modal-content { width: 85%; max-width: 400px; border-radius: 25px; overflow: hidden; border: 1px solid rgba(150,150,150,0.1); }
        .setting-item { display: flex; justify-content: space-between; align-items: center; padding: 18px 20px; border-bottom: 1px solid rgba(150,150,150,0.1); }

        @keyframes slideDown { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body>
    <div class="header">
        <span onclick="confirmLogout()" style="cursor:pointer; font-size: 1.2rem;">🚪</span>
        <h1>🍎 SmartPantry</h1>
        <div class="user-menu-container">
            <div class="user-icon" onclick="toggleMenu()">👤</div>
            <div id="dropdown" class="dropdown-menu">
                <div onclick="openModal('infoModal')" class="dropdown-item"><i class="bi bi-person-badge me-2"></i> 내 정보</div>
                <div onclick="openModal('settingsModal')" class="dropdown-item"><i class="bi bi-gear me-2"></i> 설정</div>
                <div onclick="confirmLogout()" class="dropdown-item" style="color:#ff3b30;"><i class="bi bi-box-arrow-right me-2"></i> 로그아웃</div>
            </div>
        </div>
    </div>

    <div id="ai-page" class="page active">
        <div class="analysis-card" style="margin:20px; border-radius:25px; overflow:hidden;">
            <div style="background:#e0e0e0; height:200px; display:flex; justify-content:center; align-items:center; font-size:4rem;">🍎</div>
            <div style="padding:25px;">
                <form action="/add-item" method="POST">
                    <p><b>이름:</b> <input type="text" name="item_name" value="대추사과" required style="background:transparent; border:none; border-bottom:1px solid var(--accent); color:var(--text-main); width:120px;"></p>
                    <p><b>기한:</b> <input type="date" name="expiry_date" required style="background:transparent; border:1px solid #ddd; color:var(--text-main); padding:5px; border-radius:5px;"></p>
                    <input type="hidden" name="item_emoji" value="🍎">
                    <button type="submit" style="width:100%; padding:15px; background:var(--accent); color:white; border:none; border-radius:12px; font-weight:bold; cursor:pointer;">추가하기</button>
                </form>
            </div>
        </div>
    </div>

    <div id="list-page" class="page">
        <h3 style="padding: 20px 20px 0;">🛍️ 저장고</h3>
        <% if (items && items.length > 0) { %>
            <% items.forEach(item => { %>
                <div class="item-card">
                    <span style="font-size:2rem; margin-right:15px;"><%= item.item_emoji %></span>
                    <div style="flex:1">
                        <strong><%= item.item_name %></strong><br>
                        <small style="color:#ff3b30;">~<%= new Date(item.expiry_date).toISOString().split('T')[0] %></small>
                    </div>
                    <a href="/delete-item/<%= item.id %>" onclick="return confirm('삭제할까요?')" style="text-decoration:none;">❌</a>
                </div>
            <% }) %>
        <% } else { %>
            <p style="text-align:center; color:var(--text-sub); margin-top:50px;">비어있습니다. 🧊</p>
        <% } %>
    </div>

    <div class="bottom-nav">
        <div class="nav-tab active" onclick="showPage('ai-page', this)">📷</div>
        <div class="nav-tab" onclick="showPage('list-page', this)">🛍️</div>
    </div>

    <div id="settingsModal" class="custom-modal">
        <div class="modal-content">
            <div style="padding:20px; border-bottom:1px solid rgba(150,150,150,0.2); display:flex; justify-content:space-between;">
                <strong>⚙️ 설정</strong>
                <span onclick="closeModal('settingsModal')" style="cursor:pointer; font-size:1.5rem;">×</span>
            </div>
            <div class="setting-item">
                <span>다크 모드</span>
                <input type="checkbox" id="darkModeToggle" onchange="toggleDarkMode()" style="width:22px; height:22px;">
            </div>
            <div class="setting-item" style="color:#ff3b30; cursor:pointer;" onclick="deleteAllData()">
                <span>데이터 전체 초기화 (🚨)</span>
            </div>
        </div>
    </div>

    <form id="deleteAllForm" action="/delete-all-items" method="POST" style="display:none;"></form>

    <script>
        function showPage(pageId, element) {
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            document.getElementById(pageId).classList.add('active');
            document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
            element.classList.add('active');
        }

        function toggleMenu() { document.getElementById('dropdown').classList.toggle('show'); }
        function openModal(id) { document.getElementById(id).style.display = 'flex'; document.getElementById('dropdown').classList.remove('show'); }
        function closeModal(id) { document.getElementById(id).style.display = 'none'; }

        // --- 다크모드 핵심 로직 ---
        function toggleDarkMode() {
            const isDark = document.getElementById('darkModeToggle').checked;
            const theme = isDark ? 'dark' : 'light';
            document.documentElement.setAttribute('data-theme', theme);
            localStorage.setItem('pantry-theme', theme);
            console.log("테마 변경됨:", theme); // 확인용
        }

        // 페이지 로드 시 토글 버튼 상태 동기화
        window.addEventListener('DOMContentLoaded', () => {
            const currentTheme = localStorage.getItem('pantry-theme') || 'light';
            if (currentTheme === 'dark') {
                document.getElementById('darkModeToggle').checked = true;
            }
        });

        function deleteAllData() {
            if(confirm("모든 데이터를 삭제하시겠습니까?")) {
                document.getElementById('deleteAllForm').submit();
            }
        }

        window.onclick = function(e) {
            if (!e.target.matches('.user-icon')) document.getElementById("dropdown").classList.remove('show');
            if (e.target.classList.contains('custom-modal')) e.target.style.display = 'none';
        }
    </script>
</body>
</html>